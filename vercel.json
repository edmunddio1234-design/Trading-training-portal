{
  "version": 2,
  "builds": [
    {
      "src": "api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "public/**",
      "use": "@vercel/static"
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/options-backtester.html", "destination": "/public/options-backtester.html" },
    { "source": "/training-manual.html", "destination": "/public/training-manual.html" },
    { "source": "/advanced-options-mastery.html", "destination": "/public/advanced-options-mastery.html" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ]
}
